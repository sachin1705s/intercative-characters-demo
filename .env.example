# ─── Required ───────────────────────────────────────────────────────────────
ODYSSEY_API_KEY=ody_your_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional services ───────────────────────────────────────────────────────
SMALLEST_API_KEY=your_smallest_ai_key_here
SMALLEST_EINSTEIN_VOICE_ID=your_smallest_voice_id_here
SMALLEST_EINSTEIN_VOICE_MODEL=lightning-v3.1
SMALLEST_EINSTEIN_VOICE_NAME=Jordan
EINSTEIN_MODEL=gemini-2.0-flash

# ─── Security ────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins (leave empty to allow all in dev)
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=

# ─── Database ────────────────────────────────────────────────────────────────
# Override SQLite path (auto-set to /tmp/data.sqlite on Vercel)
# DATABASE_PATH=data.sqlite
